{
  "name": "devbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch --experimental-strip-types server/index.ts",
    "dev:client": "cd client && npx vite",
    "build": "cd client && npx vite build",
    "start": "NODE_ENV=production node --experimental-strip-types server/index.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "typescript": "^5.5.0"
  }
}
